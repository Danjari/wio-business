# AWS — use me-south-1 (Bahrain) for UAE data residency
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=me-south-1

# Gemini — used for LLM fallback and categorization
GEMINI_API_KEY=

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=   # random string you set; Telegram sends it as X-Telegram-Bot-Api-Secret-Token

# Supabase
SUPABASE_URL=              # e.g. https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY= # from Supabase dashboard → Settings → API → service_role key (keep secret)

# Confidence threshold below which Textract triggers LLM text fallback (0–100, Textract scale)
TEXTRACT_CONFIDENCE_THRESHOLD=80

# Public URL for the webhook (ngrok or production hostname)
WEBHOOK_HOST=
