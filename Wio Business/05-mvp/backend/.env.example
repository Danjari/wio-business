# AWS — use me-south-1 (Bahrain) for UAE data residency
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=me-south-1

# Gemini — used for LLM fallback and categorization
GEMINI_API_KEY=

# Slack bot (Socket Mode — no public URL / ngrok needed)
# 1. api.slack.com/apps → Create app → From scratch
# 2. Settings → Socket Mode → Enable → generate App-Level Token → SLACK_APP_TOKEN (xapp-...)
# 3. OAuth & Permissions → Bot Token Scopes: chat:write, files:read, im:history, channels:history, groups:history
# 4. Event Subscriptions → Subscribe to bot events: message.im, message.channels, message.groups
# 5. Install to workspace → copy Bot User OAuth Token → SLACK_BOT_TOKEN (xoxb-...)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Supabase
SUPABASE_URL=              # e.g. https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY= # Supabase dashboard → Settings → API → service_role key (keep secret)

# Confidence threshold below which Textract triggers LLM text fallback (0–100, Textract scale)
TEXTRACT_CONFIDENCE_THRESHOLD=80
